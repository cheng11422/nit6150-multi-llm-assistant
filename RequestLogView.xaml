<UserControl x:Class="MultiLLMProjectAssistant.UI.Views.RequestLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#2C2C2C">
    <UserControl.Resources>
        <!-- Surfaces -->
        <Style x:Key="PanelSurfaceStyle" TargetType="Border">
            <Setter Property="Background" Value="#3E3E3E"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style x:Key="InputSurfaceStyle" TargetType="Border">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="14,10"/>
        </Style>

        <Style x:Key="SearchSurfaceStyle" TargetType="Border" BasedOn="{StaticResource InputSurfaceStyle}">
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#3A638C"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2F3E50"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#3A638C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#24405A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Strict blue ComboBox (pill) -->
        <Style x:Key="StrictBlueCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#2F3E50"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8,14,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="border"
                                                Background="#2F3E50"
                                                CornerRadius="18"
                                                Height="36">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="28"/>
                                                </Grid.ColumnDefinitions>
                                                <Path x:Name="Arrow"
                                                      Grid.Column="1"
                                                      Fill="#A0A0A0"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Margin="0,2,5,0"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#3B4E64"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="14,0,32,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>

                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Grid x:Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="#2F3E50"
                                            CornerRadius="8"
                                            Margin="0,5,0,0"
                                            BorderBrush="#40546B"
                                            BorderThickness="1"/>
                                    <ScrollViewer Margin="0,5">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3B4E64"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tabs styled for dark theme -->
        <Style x:Key="ResponseTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="#CFCFCF"/>
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}"
                                Margin="0,0,8,0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBg" Property="Background" Value="#2F3E50"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBg" Property="Background" Value="#3B4E64"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListView / GridView theming (fix unreadable table text) -->
        <Style x:Key="GridViewHeaderStyle" TargetType="{x:Type GridViewColumnHeader}">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="8,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type GridViewColumnHeader}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogListViewStyle" TargetType="{x:Type ListView}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#EAEAEA"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        </Style>
        
        <Style x:Key="LogListViewItemStyle" TargetType="{x:Type ListViewItem}">
            <Setter Property="Foreground" Value="#EAEAEA"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListViewItem}">
                        <Border x:Name="RowBg"
                                Background="#2D2D2D"
                                BorderBrush="#444444"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="8,10">
                            <GridViewRowPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBg" Property="Background" Value="#333333"/>
                                <Setter TargetName="RowBg" Property="BorderBrush" Value="#3B4E64"/>
                            </Trigger>
                            <!-- Theme blue selection (consistent with your other screens) -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowBg" Property="Background" Value="#263B4E64"/>
                                <Setter TargetName="RowBg" Property="BorderBrush" Value="#3A638C"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Request Log"
                           FontFamily="Segoe UI"
                           FontSize="30"
                           FontWeight="SemiBold"
                           Foreground="#FFFFFF"/>
                <TextBlock Text="Trace every request across providers with raw and normalized outputs."
                           Foreground="#A0A0A0"
                           FontSize="13"
                           Margin="0,6,0,0"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Height="1" Background="#444444" Margin="0,0,0,18"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: History List -->
            <Border Grid.Column="0" Style="{StaticResource PanelSurfaceStyle}" Margin="0,0,15,0">
                <Grid>
                <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                    <!-- Filters -->
                    <Border Grid.Row="0" Style="{StaticResource SearchSurfaceStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                            <TextBlock Text="🔎" Foreground="#A0A0A0" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Grid Grid.Column="1">
                                <TextBox x:Name="LogSearchTextBox"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="#EAEAEA"
                                         CaretBrush="White"
                                         FontSize="13"
                                         VerticalAlignment="Center"
                                         TextChanged="LogFilters_Changed"/>
                                <TextBlock Text="Search requests..."
                                           Foreground="#A0A0A0"
                                           FontSize="13"
                                           IsHitTestVisible="False"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding ElementName=LogSearchTextBox, Path=IsKeyboardFocusWithin}" Value="False"/>
                                                        <Condition Binding="{Binding ElementName=LogSearchTextBox, Path=Text}" Value=""/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <ComboBox x:Name="DateFilterComboBox"
                                      Grid.Column="2"
                                      Width="140"
                                      Margin="12,0,0,0"
                                      Style="{StaticResource StrictBlueCombo}"
                                      SelectionChanged="LogFilters_Changed">
                                <ComboBoxItem Content="All time" IsSelected="True"/>
                                <ComboBoxItem Content="Today"/>
                                <ComboBoxItem Content="Last 7 days"/>
                            </ComboBox>
                            </Grid>
                        </Border>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,14,0,10">
                        <ComboBox x:Name="ProjectFilterComboBox"
                                  Width="180"
                                  Margin="0,0,12,0"
                                  Style="{StaticResource StrictBlueCombo}"
                                  SelectionChanged="LogFilters_Changed"/>
                        <ComboBox x:Name="ProviderFilterComboBox"
                                  Width="160"
                                  Margin="0,0,12,0"
                                  Style="{StaticResource StrictBlueCombo}"
                                  SelectionChanged="LogFilters_Changed">
                            <ComboBoxItem Content="All providers" IsSelected="True"/>
                            <ComboBoxItem Content="OpenAI-GPT4"/>
                            <ComboBoxItem Content="Gemini-Pro"/>
                        </ComboBox>
                        <ComboBox x:Name="StatusFilterComboBox"
                                  Width="150"
                                  Style="{StaticResource StrictBlueCombo}"
                                  SelectionChanged="LogFilters_Changed">
                            <ComboBoxItem Content="All status" IsSelected="True"/>
                            <ComboBoxItem Content="Success"/>
                            <ComboBoxItem Content="Error"/>
                            <ComboBoxItem Content="Rate Limit"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- List -->
                    <ListView x:Name="LogListView"
                              Grid.Row="2"
                              Style="{StaticResource LogListViewStyle}"
                              ItemContainerStyle="{StaticResource LogListViewItemStyle}"
                              SizeChanged="LogListView_SizeChanged"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              SelectionChanged="LogListView_SelectionChanged">
                        <ListView.View>
                            <GridView ColumnHeaderContainerStyle="{StaticResource GridViewHeaderStyle}">
                                <GridViewColumn x:Name="TimestampColumn" Header="Timestamp" Width="170" DisplayMemberBinding="{Binding TimestampDisplay}"/>
                                <GridViewColumn x:Name="ProjectColumn" Header="Project" Width="170" DisplayMemberBinding="{Binding ProjectDisplay}"/>
                                <GridViewColumn x:Name="ProviderColumn" Header="Provider" Width="130" DisplayMemberBinding="{Binding Provider}"/>
                                <GridViewColumn x:Name="StatusColumn" Header="Status" Width="240">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding StatusBackground}"
                                                    CornerRadius="10"
                                                    Padding="8,4">
                                                <TextBlock Text="{Binding StatusDisplay}"
                                                           Foreground="{Binding StatusForeground}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
            </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" Background="Transparent" Margin="0,0,0,0"/>

            <!-- Right: Trace Detail Pane -->
            <Border Grid.Column="2" Style="{StaticResource PanelSurfaceStyle}" Margin="15,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{Binding ElementName=LogListView, Path=SelectedItem.DetailTitle}"
                               Foreground="#FFFFFF"
                               FontSize="14"
                               FontWeight="SemiBold"/>
                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button x:Name="LoadRecordButton"
                                Content="Load Into Builder"
                                Width="150"
                                Height="34"
                                Margin="0,0,10,0"
                                Style="{StaticResource ActionButtonStyle}"
                                Click="LoadRecord_Click"/>
                        <Button x:Name="DeleteRecordButton"
                                Content="Delete Record"
                                Width="120"
                                Height="34"
                                Style="{StaticResource ActionButtonStyle}"
                                Click="DeleteRecord_Click"/>
                    </StackPanel>
                    <Border Grid.Row="1" Height="1" Background="#444444" Margin="0,14,0,14"/>

                    <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0" SelectedIndex="3">
                        <TabItem Header="Request JSON" Style="{StaticResource ResponseTabItemStyle}">
                            <Border Background="#2D2D2D" CornerRadius="12" Padding="12">
                                <TextBox x:Name="RequestJsonTextBox"
                                         FontFamily="Consolas"
                                         FontSize="13"
                                         Background="Transparent"
                                         Foreground="#EAEAEA"
                                         BorderThickness="0"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"/>
                            </Border>
                        </TabItem>
                        <TabItem Header="Raw JSON" Style="{StaticResource ResponseTabItemStyle}">
                            <Border Background="#2D2D2D" CornerRadius="12" Padding="12">
                                <TextBox x:Name="RawJsonTextBox"
                                         FontFamily="Consolas"
                                         FontSize="13"
                                         Background="Transparent"
                                         Foreground="#EAEAEA"
                                         BorderThickness="0"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"/>
                            </Border>
                        </TabItem>
                        <TabItem Header="Normalized JSON" Style="{StaticResource ResponseTabItemStyle}">
                            <Border Background="#2D2D2D" CornerRadius="12" Padding="12">
                                <TextBox x:Name="NormalizedJsonTextBox"
                                         FontFamily="Consolas"
                                         FontSize="13"
                                         Background="Transparent"
                                         Foreground="#EAEAEA"
                                         BorderThickness="0"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"/>
                            </Border>
                        </TabItem>
                        <TabItem Header="Summary" Style="{StaticResource ResponseTabItemStyle}">
                            <Border Background="#2D2D2D" CornerRadius="12" Padding="12">
                                <TextBox x:Name="SummaryTextBox"
                                         FontFamily="Segoe UI"
                                         FontSize="13"
                                         Background="Transparent"
                                         Foreground="#EAEAEA"
                                         BorderThickness="0"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"/>
                            </Border>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
