<UserControl x:Class="MultiLLMProjectAssistant.UI.Views.ProjectMemoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#2C2C2C">
    <UserControl.Resources>
        <!-- Surfaces -->
        <Style x:Key="PanelSurfaceStyle" TargetType="Border">
            <Setter Property="Background" Value="#3E3E3E"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style x:Key="InputSurfaceStyle" TargetType="Border">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="14,10"/>
        </Style>

        <Style x:Key="SearchSurfaceStyle" TargetType="Border" BasedOn="{StaticResource InputSurfaceStyle}">
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#3A638C"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Buttons -->
        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2F3E50"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#3A638C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#24405A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#262626"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconTextButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#3A638C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tag filter chips -->
        <Style x:Key="TagChipStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#3A3A3A"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#2F3E50"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#2F3E50"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- List item look -->
        <Style x:Key="MemoryListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="MemoryListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Card"
                                Background="#2D2D2D"
                                BorderBrush="#444444"
                                BorderThickness="1"
                                CornerRadius="16"
                                Padding="16">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="#343434"/>
                                <Setter TargetName="Card" Property="BorderBrush" Value="#3A638C"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="#3A343A"/>
                                <Setter TargetName="Card" Property="Background" Value="#2A3746"/>
                                <Setter TargetName="Card" Property="BorderBrush" Value="#2F3E50"/>
                                <Setter TargetName="Card" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Project Memory"
                           FontFamily="Segoe UI"
                           FontSize="30"
                           FontWeight="SemiBold"
                           Foreground="#FFFFFF"/>
                <TextBlock Text="Manage reusable context snippets for injection into requests."
                           Foreground="#A0A0A0"
                           FontSize="13"
                           Margin="0,6,0,0"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="+ Add Memory Item"
                    Style="{StaticResource PrimaryActionButtonStyle}"
                    MinWidth="190"
                    VerticalAlignment="Top"
                    Margin="0,2,0,0"
                    Click="AddMemory_Click"/>
        </Grid>

        <Border Grid.Row="1" Height="1" Background="#444444" Margin="0,0,0,18"/>

        <!-- Split layout -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: list + search + filters + top-k -->
            <Border Grid.Column="0" Style="{StaticResource PanelSurfaceStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- search -->
                    <Border Grid.Row="0" Style="{StaticResource SearchSurfaceStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔎" Foreground="#A0A0A0" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Grid Grid.Column="1">
                                <TextBox x:Name="MemorySearchTextBox"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="#EAEAEA"
                                         CaretBrush="White"
                                         FontSize="13"
                                         VerticalAlignment="Center"
                                         TextChanged="MemorySearchTextBox_TextChanged"/>
                                <TextBlock Text="Search memory..."
                                           Foreground="#A0A0A0"
                                           FontSize="13"
                                           IsHitTestVisible="False"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding ElementName=MemorySearchTextBox, Path=IsKeyboardFocusWithin}" Value="False"/>
                                                        <Condition Binding="{Binding ElementName=MemorySearchTextBox, Path=Text}" Value=""/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- tag filters -->
                    <StackPanel Grid.Row="1" Margin="0,14,0,0">
                        <TextBlock Text="Filter by tags"
                                   Foreground="#A0A0A0"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Margin="2,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <ToggleButton x:Name="TagApiToggle" Content="api" Style="{StaticResource TagChipStyle}" Checked="TagFilter_Changed" Unchecked="TagFilter_Changed"/>
                            <ToggleButton x:Name="TagArchitectureToggle" Content="architecture" Style="{StaticResource TagChipStyle}" Checked="TagFilter_Changed" Unchecked="TagFilter_Changed"/>
                            <ToggleButton x:Name="TagDatabaseToggle" Content="database" Style="{StaticResource TagChipStyle}" Checked="TagFilter_Changed" Unchecked="TagFilter_Changed"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Top-K default -->
                    <Grid Grid.Row="2" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Default Top-K injection"
                                       Foreground="#FFFFFF"
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Used when injecting memory into requests."
                                       Foreground="#A0A0A0"
                                       FontSize="11"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Background="#D0D0D0"
                                CornerRadius="10"
                                Padding="10,2"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="DefaultTopKText"
                                           Text="5"
                                           Foreground="#333333"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           Width="10"
                                           TextAlignment="Center"/>
                                <StackPanel VerticalAlignment="Center">
                                    <Button Content="▲" Style="{StaticResource IconTextButton}" Foreground="#333333" FontSize="7" Height="10" Click="IncreaseDefaultTopK_Click"/>
                                    <Button Content="▼" Style="{StaticResource IconTextButton}" Foreground="#333333" FontSize="7" Height="10" Click="DecreaseDefaultTopK_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- list -->
                    <ListBox x:Name="MemoryListBox"
                             Grid.Row="3"
                             Margin="0,16,0,0"
                             Style="{StaticResource MemoryListBoxStyle}"
                             ItemContainerStyle="{StaticResource MemoryListBoxItemStyle}"
                             SelectionChanged="MemoryListBox_SelectionChanged"/>
                </Grid>
            </Border>

            <!-- spacer -->
            <Border Grid.Column="1" Background="Transparent"/>

            <!-- RIGHT: detail panel -->
            <Border Grid.Column="2" Style="{StaticResource PanelSurfaceStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Details"
                                   Foreground="#FFFFFF"
                                   FontSize="14"
                                   FontWeight="SemiBold"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Delete" Style="{StaticResource SecondaryActionButtonStyle}" Margin="0,0,10,0" Click="DeleteMemory_Click"/>
                            <Button Content="Save" Style="{StaticResource PrimaryActionButtonStyle}" Click="SaveMemory_Click"/>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1" Height="1" Background="#444444" Margin="0,14,0,14"/>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Title" Foreground="#A0A0A0" FontSize="11" FontWeight="SemiBold" Margin="2,0,0,6"/>
                        <Border Grid.Row="0" Style="{StaticResource InputSurfaceStyle}" Margin="0,20,0,0">
                            <TextBox x:Name="TitleTextBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#FFFFFF"
                                     CaretBrush="White"
                                     FontSize="13"/>
                        </Border>

                        <TextBlock Grid.Row="1" Text="Tags (comma-separated)" Foreground="#A0A0A0" FontSize="11" FontWeight="SemiBold" Margin="2,14,0,6"/>
                        <Border Grid.Row="1" Style="{StaticResource InputSurfaceStyle}" Margin="0,34,0,0">
                            <TextBox x:Name="TagsTextBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#FFFFFF"
                                     CaretBrush="White"
                                     FontSize="13"/>
                        </Border>

                        <TextBlock Grid.Row="2" Text="Timestamp" Foreground="#A0A0A0" FontSize="11" FontWeight="SemiBold" Margin="2,14,0,6"/>
                        <Border Grid.Row="2" Style="{StaticResource InputSurfaceStyle}" Margin="0,34,0,0">
                            <TextBox x:Name="TimestampTextBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#A0A0A0"
                                     FontSize="13"
                                     IsReadOnly="True"/>
                        </Border>

                        <TextBlock Grid.Row="3" Text="Content" Foreground="#A0A0A0" FontSize="11" FontWeight="SemiBold" Margin="2,14,0,6"/>
                        <Border Grid.Row="3" Background="#2D2D2D" BorderBrush="#444444" BorderThickness="1" CornerRadius="14" Padding="12" Margin="0,34,0,0">
                            <TextBox x:Name="ContentTextBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#EAEAEA"
                                     CaretBrush="White"
                                     FontSize="13"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled"/>
                        </Border>
                    </Grid>

                    <TextBlock Grid.Row="3"
                               Text="Tip: Keep memory items short and specific for better injection quality."
                               Foreground="#A0A0A0"
                               FontSize="11"
                               Margin="0,14,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
