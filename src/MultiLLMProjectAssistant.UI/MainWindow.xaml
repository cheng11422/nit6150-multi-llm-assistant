<Window x:Class="MultiLLMProjectAssistant.UI.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MultiLLMProjectAssistant.UI"
        Title="Multi-LLM Project Assistant"
        Height="720"
        Width="1080"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Themed tooltip for collapsed icon rail -->
        <Style x:Key="SidebarToolTipStyle" TargetType="ToolTip">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Placement" Value="Right"/>
            <Setter Property="HorizontalOffset" Value="14"/>
            <Setter Property="VerticalOffset" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="#2B2B2B"
                                BorderBrush="#3A638C"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="10,6"
                                Opacity="0.96">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Chevron button: color-only hover -->
        <Style x:Key="SidebarChevronButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#3A638C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Foreground" Value="#6FA6D8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar container padding/margins (expanded vs collapsed) -->
        <Style x:Key="SidebarContainerStyle" TargetType="Border">
            <Setter Property="Margin" Value="20"/>
            <Setter Property="CornerRadius" Value="28"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <!-- reduce outer margin when collapsed so icons fit -->
                <DataTrigger Binding="{Binding ElementName=RootWindow, Path=IsSidebarExpanded}" Value="False">
                    <!-- keep top/bottom equal to expanded; only shrink left/right -->
                    <Setter Property="Margin" Value="8,20,8,20"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SidebarInnerGridStyle" TargetType="Grid">
            <Setter Property="Margin" Value="24"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=RootWindow, Path=IsSidebarExpanded}" Value="False">
                    <!-- keep top/bottom equal to expanded; only shrink left/right -->
                    <Setter Property="Margin" Value="8,24,8,24"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Modern pill sidebar nav button -->
        <Style x:Key="SidebarNavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="ToolTipService.ShowDuration" Value="60000"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="NavBg"
                                    Background="Transparent"
                                    CornerRadius="20"
                                    Padding="{TemplateBinding Padding}"
                                    Margin="6,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="IconBlock"
                                               FontFamily="Segoe UI Symbol"
                                               FontSize="16"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"
                                               Text="{TemplateBinding Tag}"/>
                                    <ContentPresenter x:Name="LabelPresenter"
                                                      VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Tooltip label (enabled only when collapsed via triggers) -->
                            <Grid.ToolTip>
                                <ToolTip x:Name="CollapsedToolTip" Style="{StaticResource SidebarToolTipStyle}">
                                    <TextBlock Text="{TemplateBinding Content}"
                                               Foreground="#FFFFFF"
                                               FontSize="12"
                                               FontWeight="SemiBold"/>
                                </ToolTip>
                            </Grid.ToolTip>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBg" Property="Background" Value="#263B4E64"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="NavBg" Property="Background" Value="#2F3E50"/>
                            </Trigger>
                            <!-- persistent selected state (stays until another is chosen) -->
                            <Trigger Property="local:NavState.IsSelected" Value="True">
                                <Setter TargetName="NavBg" Property="Background" Value="#2F3E50"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <!-- expanded: show label, disable tooltip -->
                            <DataTrigger Binding="{Binding ElementName=RootWindow, Path=IsSidebarExpanded}" Value="True">
                                <Setter TargetName="LabelPresenter" Property="Visibility" Value="Visible"/>
                                <Setter Property="ToolTipService.IsEnabled" Value="False"/>
                            </DataTrigger>
                            <!-- collapsed: hide label -->
                            <DataTrigger Binding="{Binding ElementName=RootWindow, Path=IsSidebarExpanded}" Value="False">
                                <Setter TargetName="LabelPresenter" Property="Visibility" Value="Collapsed"/>
                                <!-- center icon + reduce padding so icons stay visible -->
                                <Setter TargetName="NavBg" Property="Padding" Value="8,10"/>
                                <Setter TargetName="NavBg" Property="HorizontalAlignment" Value="Center"/>
                                <Setter TargetName="NavBg" Property="Margin" Value="0"/>
                                <Setter TargetName="IconBlock" Property="Margin" Value="0"/>
                                <Setter TargetName="IconBlock" Property="FontSize" Value="18"/>
                                <Setter Property="ToolTipService.IsEnabled" Value="True"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Border Background="{StaticResource BrushBackground}" CornerRadius="18">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="6" Opacity="0.35"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="46"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Themed title bar (removes white window chrome) -->
                <Grid Grid.Row="0" Background="{StaticResource BrushBackground}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Multi-LLM Project Assistant"
                               Foreground="#FFFFFF"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="18,0,0,0"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                        <Button Content="—" Width="40" Height="28" Click="Minimize_Click"
                                Background="Transparent" Foreground="#FFFFFF" BorderThickness="0" Cursor="Hand"/>
                        <Button Content="▢" Width="40" Height="28" Click="Maximize_Click"
                                Background="Transparent" Foreground="#FFFFFF" BorderThickness="0" Cursor="Hand"/>
                        <Button Content="✕" Width="40" Height="28" Click="Close_Click"
                                Background="Transparent" Foreground="#FFFFFF" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </Grid>

                <!-- App content -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" MinWidth="80" x:Name="sidebarcolumn"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

        <!-- Left gradient navigation matching design -->
        <Border Grid.Column="0" Style="{StaticResource SidebarContainerStyle}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#1C222B" Offset="0.0"/>
                    <GradientStop Color="#233646" Offset="0.45"/>
                    <GradientStop Color="#20252A" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid Style="{StaticResource SidebarInnerGridStyle}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- collapse / expand button -->
                <Button x:Name="SidebarToggleButton"
                        Grid.Row="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,8,0,0"
                        Content="❮"
                        Width="30"
                        Height="30"
                        FontSize="16"
                        Style="{StaticResource SidebarChevronButtonStyle}"
                        Click="togglesidebarclick"/>

                <!-- dummy title used by code-behind for visibility -->
                <TextBlock Grid.Row="1"
                           x:Name="apptitletext"
                           Text="AI Project Assistant"
                           Foreground="Transparent"
                           Visibility="Collapsed"/>

                <!-- nav buttons (scrolls when window is short) -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel VerticalAlignment="Center">
                        <Button x:Name="NavHomeButton" Content="Home / Projects" Tag="🏠" Style="{StaticResource SidebarNavButtonStyle}" Click="showprojectselectionclick"/>
                        <Button x:Name="NavRequestBuilderButton" Content="Request Builder" Tag="📝" Style="{StaticResource SidebarNavButtonStyle}" Click="showrequestbuilderclick"/>
                        <Button x:Name="NavProjectMemoryButton" Content="Project Memory" Tag="🧠" Style="{StaticResource SidebarNavButtonStyle}" Click="showprojectmemoryclick"/>
                        <Button x:Name="NavFilesButton" Content="Files" Tag="📁" Style="{StaticResource SidebarNavButtonStyle}" Click="showfilesclick"/>
                        <Button x:Name="NavTemplatesButton" Content="Templates" Tag="📑" Style="{StaticResource SidebarNavButtonStyle}" Click="showtemplatesclick"/>
                        <Button x:Name="NavRequestLogButton" Content="Request Log" Tag="📊" Style="{StaticResource SidebarNavButtonStyle}" Click="showrequestlogclick"/>
                        <Button x:Name="NavSettingsButton" Content="Settings" Tag="⚙" Style="{StaticResource SidebarNavButtonStyle}" Click="showsettingsclick"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- bottom branding (hidden when collapsed) -->
                <StackPanel x:Name="BrandingPanel"
                            Grid.Row="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Bottom"
                            Margin="0,40,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=RootWindow, Path=IsSidebarExpanded}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <StackPanel Margin="0,0,16,0"
                                VerticalAlignment="Center">
                        <Ellipse Width="5" Height="5" Fill="#FFFFFF" Margin="0,0,0,6"/>
                        <Ellipse Width="5" Height="5" Fill="#FFFFFF" Margin="0,0,0,6"/>
                        <Ellipse Width="5" Height="5" Fill="#FFFFFF"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="AI"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="#FFFFFF"/>
                        <TextBlock Text="Project Assistant"
                                   FontSize="18"
                                   Foreground="#FFFFFF"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

                    <!-- Main content host -->
                    <Border Grid.Column="1"
                            Background="{StaticResource BrushMainContent}"
                            CornerRadius="15,0,0,15">
                        <ContentControl x:Name="maincontentarea"/>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>