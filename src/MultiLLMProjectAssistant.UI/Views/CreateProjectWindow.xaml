<Window x:Class="MultiLLMProjectAssistant.UI.Views.CreateProjectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create New Project"
        Width="560"
        Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">
    <Window.Resources>
        <Style x:Key="PanelSurfaceStyle" TargetType="Border">
            <Setter Property="Background" Value="#3E3E3E"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="22"/>
        </Style>

        <Style x:Key="InputSurfaceStyle" TargetType="Border">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="14,10"/>
        </Style>

        <Style x:Key="SearchSurfaceStyle" TargetType="Border" BasedOn="{StaticResource InputSurfaceStyle}">
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#3A638C"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#EAEAEA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="AcceptsReturn" Value="False"/>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2F3E50"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="MinWidth" Value="130"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#3A638C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#24405A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#3B4E64"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#333333"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#3A638C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#262626"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Border Background="#2C2C2C" CornerRadius="18">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="22" ShadowDepth="6" Opacity="0.35"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="46"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Custom dark title bar -->
                <Grid Grid.Row="0" Background="#2C2C2C" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Create New Project"
                               Foreground="#EAEAEA"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="18,0,0,0"/>
                    <Button Grid.Column="1"
                            Content="✕"
                            Width="36"
                            Height="30"
                            Margin="0,0,12,0"
                            Background="Transparent"
                            Foreground="#A0A0A0"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="Close_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="Transparent" CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#333333"/>
                                        <Setter Property="Foreground" Value="#FFFFFF"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#262626"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <Border Grid.Row="1" Style="{StaticResource PanelSurfaceStyle}" Margin="18,0,18,18">
                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                            <Button Content="Cancel" Style="{StaticResource SecondaryActionButtonStyle}" Click="Cancel_Click"/>
                            <Button Content="Create" Style="{StaticResource PrimaryActionButtonStyle}" Margin="10,0,0,0" Click="Create_Click"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="New Project"
                                       Foreground="#FFFFFF"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Create a project workspace for files, memory, and request logs."
                                       Foreground="#A0A0A0"
                                       FontSize="12"
                                       Margin="0,6,0,0"/>

                            <TextBlock Text="Project name"
                                       Foreground="#A0A0A0"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="2,18,0,6"/>
                            <Border Style="{StaticResource SearchSurfaceStyle}">
                                <TextBox x:Name="NameTextBox" Style="{StaticResource InputBoxStyle}"/>
                            </Border>

                            <TextBlock Text="Description (optional)"
                                       Foreground="#A0A0A0"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="2,18,0,6"/>
                            <Border Style="{StaticResource SearchSurfaceStyle}">
                                <TextBox x:Name="DescriptionTextBox"
                                         Style="{StaticResource InputBoxStyle}"
                                         AcceptsReturn="True"
                                         MinHeight="110"
                                         VerticalScrollBarVisibility="Auto"/>
                            </Border>
                        </StackPanel>
                    </DockPanel>
                </Border>

            </Grid>
        </Border>
    </Grid>
</Window>

