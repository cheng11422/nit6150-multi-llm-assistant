<Application x:Class="MultiLLMProjectAssistant.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Resource dictionary for colors and styles -->
        <Color x:Key="ColorPrimary">#354A5E</Color>
        <Color x:Key="ColorBackground">#2D2D2D</Color>
        <Color x:Key="ColorMainContent">#3E3E3E</Color>
        <Color x:Key="ColorSidebar">#273B4E</Color>
        <Color x:Key="ColorAccent">#FFFFFF</Color>

        <SolidColorBrush x:Key="BrushPrimary" Color="{StaticResource ColorPrimary}"/>
        <SolidColorBrush x:Key="BrushBackground" Color="{StaticResource ColorBackground}"/>
        <SolidColorBrush x:Key="BrushMainContent" Color="{StaticResource ColorMainContent}"/>
        <SolidColorBrush x:Key="BrushSidebar" Color="{StaticResource ColorSidebar}"/>
        <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource ColorAccent}"/>

        <!-- Global thin scrollbar (supports both vertical + horizontal) -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <!-- vertical defaults -->
            <Setter Property="Width" Value="4"/>
            <Setter Property="Margin" Value="2,0,2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="Transparent">
                            <Track x:Name="PART_Track"
                                   Orientation="{TemplateBinding Orientation}"
                                   IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#666666" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Vertical thumb: tall + thin -->
                            <Trigger Property="Orientation" Value="Vertical">
                                <Setter TargetName="Thumb" Property="MinHeight" Value="30"/>
                                <Setter TargetName="Thumb" Property="MinWidth" Value="0"/>
                            </Trigger>

                            <!-- Horizontal scrollbar thickness -->
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Height" Value="4"/>
                                <Setter Property="Width" Value="Auto"/>
                                <Setter Property="Margin" Value="0,2,0,2"/>
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="false"/>
                                <Setter TargetName="Thumb" Property="MinWidth" Value="30"/>
                                <Setter TargetName="Thumb" Property="MinHeight" Value="0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
