<UserControl x:Class="MultiLLMProjectAssistant.UI.Views.TaskTemplatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#2C2C2C">
    <UserControl.Resources>
        <!-- Surfaces -->
        <Style x:Key="PanelSurfaceStyle" TargetType="Border">
            <Setter Property="Background" Value="#3E3E3E"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style x:Key="InputSurfaceStyle" TargetType="Border">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="14,10"/>
        </Style>

        <Style x:Key="SearchSurfaceStyle" TargetType="Border" BasedOn="{StaticResource InputSurfaceStyle}">
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#3A638C"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Buttons -->
        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2F3E50"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#3A638C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#24405A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#262626"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- List item cards -->
        <Style x:Key="TemplateListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="TemplateListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Card"
                                Background="#2D2D2D"
                                BorderBrush="#444444"
                                BorderThickness="1"
                                CornerRadius="16"
                                Padding="16">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="#343434"/>
                                <Setter TargetName="Card" Property="BorderBrush" Value="#3A638C"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="#2A3746"/>
                                <Setter TargetName="Card" Property="BorderBrush" Value="#2F3E50"/>
                                <Setter TargetName="Card" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="30" KeyDown="Root_KeyDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel>
                <TextBlock Text="Task Templates"
                           FontFamily="Segoe UI"
                           FontSize="30"
                           FontWeight="SemiBold"
                           Foreground="#FFFFFF"/>
                <TextBlock Text="Create reusable prompts and JSON workflows."
                           Foreground="#A0A0A0"
                           FontSize="13"
                           Margin="0,6,0,0"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="+ New Template"
                    Style="{StaticResource PrimaryActionButtonStyle}"
                    VerticalAlignment="Top"
                    Margin="0,2,0,0"
                    MinWidth="170"
                    Click="NewTemplate_Click"/>
        </Grid>

        <Border Grid.Row="1" Height="1" Background="#444444" Margin="0,0,0,18"/>

        <!-- Split layout -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: search + list -->
            <Border Grid.Column="0" Style="{StaticResource PanelSurfaceStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource SearchSurfaceStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔎" Foreground="#A0A0A0" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Grid Grid.Column="1">
                                <TextBox x:Name="TemplateSearchTextBox"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="#EAEAEA"
                                         CaretBrush="White"
                                         FontSize="13"
                                         VerticalAlignment="Center"
                                         TextChanged="TemplateSearchTextBox_TextChanged"/>
                                <TextBlock Text="Search templates..."
                                           Foreground="#A0A0A0"
                                           FontSize="13"
                                           IsHitTestVisible="False"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding ElementName=TemplateSearchTextBox, Path=IsKeyboardFocusWithin}" Value="False"/>
                                                        <Condition Binding="{Binding ElementName=TemplateSearchTextBox, Path=Text}" Value=""/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="1"
                               Text="Saved templates"
                               Foreground="#A0A0A0"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="2,14,0,10"/>

                    <ListBox x:Name="TemplatesListBox"
                             Grid.Row="2"
                             Style="{StaticResource TemplateListStyle}"
                             ItemContainerStyle="{StaticResource TemplateListItemStyle}"
                             SelectionChanged="TemplatesListBox_SelectionChanged"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="Transparent"/>

            <!-- RIGHT: edit/preview -->
            <Border Grid.Column="2" Style="{StaticResource PanelSurfaceStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Template Details"
                                   Foreground="#FFFFFF"
                                   FontSize="14"
                                   FontWeight="SemiBold"/>

                        <WrapPanel Grid.Row="1"
                                   Margin="0,12,0,0"
                                   HorizontalAlignment="Right"
                                   ItemHeight="36">
                            <Button x:Name="ApplyButton"
                                    Content="Apply to Request Builder"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Margin="0,0,10,10"
                                    MinWidth="220"
                                    Click="ApplyToRequestBuilder_Click"/>

                            <Button x:Name="DeleteButton"
                                    Content="Delete"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Margin="0,0,10,10"
                                    MinWidth="120"
                                    Click="DeleteTemplate_Click"/>

                            <Button x:Name="SaveButton"
                                    Content="Save"
                                    Style="{StaticResource PrimaryActionButtonStyle}"
                                    Margin="0,0,0,10"
                                    MinWidth="120"
                                    Click="SaveTemplate_Click"/>
                        </WrapPanel>
                    </Grid>

                    <Border Grid.Row="1" Height="1" Background="#444444" Margin="0,14,0,14"/>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Name" Foreground="#A0A0A0" FontSize="11" FontWeight="SemiBold" Margin="2,0,0,6"/>
                        <Border Grid.Row="0" Style="{StaticResource InputSurfaceStyle}" Margin="0,20,0,0">
                            <TextBox x:Name="NameTextBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#FFFFFF"
                                     CaretBrush="White"
                                     FontSize="13"
                                     TextChanged="Editor_TextChanged"/>
                        </Border>

                        <TextBlock Grid.Row="1" Text="Description" Foreground="#A0A0A0" FontSize="11" FontWeight="SemiBold" Margin="2,14,0,6"/>
                        <Border Grid.Row="1" Style="{StaticResource InputSurfaceStyle}" Margin="0,34,0,0">
                            <TextBox x:Name="DescriptionTextBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#FFFFFF"
                                     CaretBrush="White"
                                     FontSize="13"
                                     TextWrapping="Wrap"
                                     TextChanged="Editor_TextChanged"/>
                        </Border>

                        <TextBlock Grid.Row="2" Text="Last modified" Foreground="#A0A0A0" FontSize="11" FontWeight="SemiBold" Margin="2,14,0,6"/>
                        <Border Grid.Row="2" Style="{StaticResource InputSurfaceStyle}" Margin="0,34,0,0">
                            <TextBox x:Name="LastModifiedTextBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#A0A0A0"
                                     FontSize="13"
                                     IsReadOnly="True"/>
                        </Border>

                        <TextBlock Grid.Row="3" Text="Template JSON / content" Foreground="#A0A0A0" FontSize="11" FontWeight="SemiBold" Margin="2,14,0,6"/>
                        <Border Grid.Row="3" Background="#2D2D2D" BorderBrush="#444444" BorderThickness="1" CornerRadius="14" Padding="12" Margin="0,34,0,0">
                            <TextBox x:Name="ContentTextBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#EAEAEA"
                                     CaretBrush="White"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     AcceptsReturn="True"
                                     AcceptsTab="True"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     TextChanged="Editor_TextChanged"/>
                        </Border>
                    </Grid>

                    <TextBlock Grid.Row="3"
                               Text="Tip: Keep templates consistent so responses stay traceable."
                               Foreground="#A0A0A0"
                               FontSize="11"
                               Margin="0,14,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
