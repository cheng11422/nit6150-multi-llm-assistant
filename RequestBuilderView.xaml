<UserControl x:Class="MultiLLMProjectAssistant.UI.Views.RequestBuilderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#282828">

    <UserControl.Resources>
        
        <!-- ScrollBar style moved to App.xaml for global consistency -->

        <!-- STRICT BLUE COMBOBOX: Forces blue color always, ignoring Windows default themes -->
        <Style x:Key="StrictBlueCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#2F3E50"/> 
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,10,18,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Grid.Column="2" Focusable="false" IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <!-- Forces the background to be strictly Blue at all times -->
                                        <Border Background="#2F3E50" CornerRadius="20" x:Name="border" Height="40">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                </Grid.ColumnDefinitions>
                                                <Path x:Name="Arrow" Grid.Column="1" Fill="#A0A0A0" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z" Margin="0,2,5,0"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#3B4E64"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="15,0,30,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#2F3E50" CornerRadius="8" Margin="0,5,0,0" BorderBrush="#40546B" BorderThickness="1"/>
                                    <ScrollViewer Margin="0,5">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3B4E64"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- INPUT BOX STYLE (Blue border on focus) -->
        <Style x:Key="InputBoxStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#4A4A4A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="#282828"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#3A638C"/> 
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- NEW: ICON HOVER STYLE (Icon turns blue, background stays transparent) -->
        <Style x:Key="IconTextButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" FontSize="{TemplateBinding FontSize}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#3A638C"/> <!-- Icon text turns blue -->
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="SwitchBg" Width="36" Height="20" CornerRadius="10" Background="#4A4A4A" VerticalAlignment="Center">
                            <Ellipse x:Name="SwitchThumb" Width="14" Height="14" Fill="White" HorizontalAlignment="Left" Margin="3,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchBg" Property="Background" Value="#2F3E50"/>
                                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="SwitchThumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AttachmentPill" TargetType="Border">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>

        <!-- Primary / secondary actions -->
        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2F3E50"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#3A638C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#24405A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#4A4A4A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#2F2F2F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tabs styled for dark theme -->
        <Style x:Key="ResponseTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="#CFCFCF"/>
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}"
                                Margin="0,0,8,0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBg" Property="Background" Value="#2F3E50"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBg" Property="Background" Value="#3B4E64"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- MAIN CONTENT AREA (navbar is in MainWindow) -->
    <Grid Background="#2C2C2C" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 1. HEADER -->
            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Multi-LLM Request Builder" FontFamily="Segoe UI" FontSize="30" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                    <TextBlock x:Name="CurrentProjectTextBlock"
                               Text="Current project: No project selected"
                               Foreground="#A0A0A0"
                               FontSize="13"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="40,0,30,0">
                    <TextBlock Text="Provider:" Foreground="#A0A0A0" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12"/>
                    <ComboBox x:Name="ProviderComboBox" Style="{StaticResource StrictBlueCombo}" Width="170" SelectionChanged="ProviderComboBox_SelectionChanged">
                        <ComboBoxItem Content="OpenAI-GPT4" IsSelected="True"/>
                        <ComboBoxItem Content="Gemini-Pro"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Template:" Foreground="#A0A0A0" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12"/>
                    <ComboBox x:Name="TemplateComboBox" Style="{StaticResource StrictBlueCombo}" Width="170" SelectionChanged="TemplateComboBox_SelectionChanged">
                        <ComboBoxItem Content="Code Review" IsSelected="True"/>
                        <ComboBoxItem Content="Data Processing"/>
                        <ComboBoxItem Content="Literature Analysis"/>
                        <ComboBoxItem Content="Research Summary"/>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <!-- Divider -->
            <Border Grid.Row="1" Height="1" Background="#444444" Margin="0,0,0,18"/>

            <!-- 2. JSON REQUEST + RESPONSE -->
            <Border Grid.Row="2" Background="#3E3E3E" CornerRadius="18" Padding="22" Margin="0,0,0,18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="180"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="2,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="JSON Request"
                                   Foreground="#FFFFFF"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="Cancel"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Margin="0,0,10,0"
                                    Click="Cancel_Click"/>
                            <Button Content="Submit Request"
                                    Style="{StaticResource PrimaryActionButtonStyle}"
                                    Click="SubmitRequest_Click"/>
                        </StackPanel>
                    </Grid>

                    <Border x:Name="JsonRequestBorder"
                            Grid.Row="1"
                            Background="#2D2D2D"
                            BorderBrush="#444444"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="#444444"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                        <Setter Property="BorderBrush" Value="#3A638C"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBox x:Name="JsonRequestTextBox"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 Background="Transparent"
                                 Foreground="#EAEAEA"
                                 CaretBrush="White"
                                 BorderThickness="0"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextChanged="JsonRequestTextBox_TextChanged"
                                 KeyDown="JsonRequestTextBox_KeyDown"/>
                    </Border>

                    <TextBlock Grid.Row="2"
                               Text="LLM Response"
                               Foreground="#FFFFFF"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="2,18,0,8"/>

                    <TabControl Grid.Row="3"
                                Background="Transparent"
                                BorderThickness="0"
                                SelectedIndex="2">
                        <TabItem Header="Raw JSON" Style="{StaticResource ResponseTabItemStyle}">
                            <Border Background="#2D2D2D" CornerRadius="12" Padding="12">
                                <TextBox x:Name="RawJsonResponseTextBox"
                                         FontFamily="Consolas"
                                         FontSize="13"
                                         Background="Transparent"
                                         Foreground="#EAEAEA"
                                         CaretBrush="White"
                                         BorderThickness="0"
                                         AcceptsReturn="True"
                                         TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         IsReadOnly="True"/>
                            </Border>
                        </TabItem>
                        <TabItem Header="Normalized JSON" Style="{StaticResource ResponseTabItemStyle}">
                            <Border Background="#2D2D2D" CornerRadius="12" Padding="12">
                                <TextBox x:Name="NormalizedJsonResponseTextBox"
                                         FontFamily="Consolas"
                                         FontSize="13"
                                         Background="Transparent"
                                         Foreground="#EAEAEA"
                                         CaretBrush="White"
                                         BorderThickness="0"
                                         AcceptsReturn="True"
                                         TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         IsReadOnly="True"/>
                            </Border>
                        </TabItem>
                        <TabItem Header="Summary" Style="{StaticResource ResponseTabItemStyle}">
                            <Border Background="#2D2D2D" CornerRadius="12" Padding="12">
                                <TextBox x:Name="SummaryResponseTextBox"
                                         FontFamily="Segoe UI"
                                         FontSize="13"
                                         Background="Transparent"
                                         Foreground="#EAEAEA"
                                         CaretBrush="White"
                                         BorderThickness="0"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         IsReadOnly="True"/>
                            </Border>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>

            <!-- 3. FOOTER -->
            <Grid Grid.Row="3">
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Attached Files (clickable + horizontal scroll) -->
                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <Button Click="AttachFiles_Click"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                HorizontalAlignment="Left"
                                Cursor="Hand"
                                Margin="0,0,0,8"
                                ToolTip="Attach files">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="📎" Foreground="#A0A0A0" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Attached Files" Foreground="#FFFFFF" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.92"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Single-row: horizontal scroll only (no wrapping) -->
                        <ScrollViewer x:Name="AttachmentsScrollViewer"
                                      VerticalScrollBarVisibility="Disabled"
                                      HorizontalScrollBarVisibility="Visible"
                                      PanningMode="HorizontalOnly"
                                      PreviewMouseWheel="AttachmentsScrollViewer_PreviewMouseWheel"
                                      Height="48"
                                      Padding="0,0,0,6">
                            <StackPanel x:Name="AttachmentsPanel"
                                        Orientation="Horizontal"/>
                        </ScrollViewer>
                    </StackPanel>

                    <!-- Memory Toggles & Functional Top-K -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,25,0">

                        <StackPanel VerticalAlignment="Center" Margin="0,0,10,0">
                            <TextBlock Text="Project Memory" Foreground="#FFFFFF" FontSize="12" HorizontalAlignment="Right"/>
                            <TextBlock Text="Enabled" Foreground="#A0A0A0" FontSize="10" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                        </StackPanel>

                        <CheckBox x:Name="ProjectMemoryCheckBox" Style="{StaticResource ToggleSwitchStyle}" IsChecked="True" Margin="0,0,20,0" Click="ProjectMemoryCheckBox_Click"/>

                        <TextBlock Text="Top-K" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12"/>

                        <!-- FUNCTIONAL TOP-K BUTTONS -->
                        <Border Background="#D0D0D0" CornerRadius="10" Padding="10,2" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="TopKText" Text="5" Foreground="#333333" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0" Width="10" TextAlignment="Center"/>

                                <!-- Up/Down arrows grouped together -->
                                <StackPanel VerticalAlignment="Center">
                                    <Button Content="▲" Style="{StaticResource IconTextButton}" Foreground="#333333" FontSize="7" Height="10" Click="IncreaseTopK_Click"/>
                                    <Button Content="▼" Style="{StaticResource IconTextButton}" Foreground="#333333" FontSize="7" Height="10" Click="DecreaseTopK_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                </Grid>
            </Grid>
        </Grid>
</UserControl>
